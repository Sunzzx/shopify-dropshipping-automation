# CJ Dropshipping & Shopify API Configuration
# Copy this file to .env and fill in your actual credentials

# CJ Dropshipping API Credentials
CJ_EMAIL=your-cj-email@example.com
CJ_PASSWORD=your-cj-password
CJ_API_KEY=your-cj-api-key
CJ_API_SECRET=your-cj-api-secret

# Shopify Store Configuration
SHOPIFY_SHOP_DOMAIN=your-shop-name.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-access-token

# Optional Configuration
NODE_ENV=production
LOG_LEVEL=info

# Automation Settings
DEFAULT_MARKUP=2.5
MAX_PRODUCTS_PER_BATCH=10
RATE_LIMIT_DELAY=1000
